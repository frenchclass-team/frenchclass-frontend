<view class="container">
  <view class="header">
    <text class="title">法语优课</text>
    <text class="subtitle">登录你的学习账号</text>
  </view>

  <view class="form-group">
    <input class="input-box" placeholder="请输入手机号" model:value="{{identifier}}" type="number" />
    <input class="input-box" placeholder="请输入密码" model:value="{{password}}" password />
    
    <radio-group class="role-group" bindchange="onRoleChange">
      <label class="radio-label">
        <radio value="student" checked="{{role === 'student'}}" color="#000000"/> 学生
      </label>
      <label class="radio-label">
        <radio value="teacher" checked="{{role === 'teacher'}}" color="#000000"/> 教师
      </label>
    </radio-group>
  </view>

  <button class="btn-primary" bindtap="handleLogin" loading="{{loading}}">登 录</button>
</view>