.container { padding: 40rpx; }
.header { margin-bottom: 40rpx; }
.title { font-size: 56rpx; font-weight: bold; color: #000; display: block; }
.subtitle { font-size: 28rpx; color: #999; margin-top: 10rpx; display: block; }

.list-container {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #f0f0f0;
}
.list-item:last-child { border-bottom: none; }

.verb-text {
  font-size: 34rpx;
  color: #333;
  font-family: Georgia, serif; /* 法语动词用衬线字体比较优雅 */
}

/* 简单的右侧箭头用 CSS 画 */
.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #ccc;
  border-right: 4rpx solid #ccc;
  transform: rotate(45deg);
}

.empty-state {
  text-align: center;
  margin-top: 100rpx;
  color: #999;
  font-size: 28rpx;
}