<view class="profile-container">
  <view class="user-info">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="info-text">
      <text class="nickname">{{userInfo.nickname || '未命名用户'}}</text>
      <text class="role-tag">{{userInfo.role === 'teacher' ? '教师' : '学生'}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="handleSetting">
      <text>设置</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="logout-btn-wrapper pb-safe">
    <button class="btn-logout" bindtap="handleLogout">退出登录</button>
  </view>
</view>