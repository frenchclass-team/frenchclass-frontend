.container { padding: 30rpx; }
.article-list { display: flex; flex-direction: column; }
.article-card {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}
.cover-img {
  width: 100%;
  height: 100%;
  filter: brightness(0.6); /* CSS滤镜调暗背景以凸显文字 */
  transition: transform 0.3s;
}
.article-card:active .cover-img {
  transform: scale(1.02);
}
.title-overlay {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
}
.title-fr {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  font-family: Georgia, serif;
}
.title-zh {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}
.loading-tip, .bottom-tip {
  text-align: center; font-size: 24rpx; color: #999; margin: 30rpx 0;
}