.container { padding: 40rpx; background: #f7f8fa; height: 100vh; }
.header { margin-bottom: 60rpx; }
.title { font-size: 56rpx; font-weight: bold; color: #000; display: block; margin-bottom: 10rpx; }
.subtitle { font-size: 28rpx; color: #999; }

.translate-box { background: #fff; border-radius: 20rpx; padding: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); }
.lang-switch { display: flex; align-items: center; justify-content: space-around; padding-bottom: 30rpx; border-bottom: 1px dashed #eee; margin-bottom: 30rpx; }
.lang { font-size: 32rpx; color: #666; font-weight: 500; }
.lang.active { color: #000; }
.icon { font-size: 40rpx; color: #ccc; }

.input-area { width: 100%; height: 300rpx; font-size: 32rpx; color: #333; line-height: 1.5; }
.action-bar { margin-top: 30rpx; display: flex; justify-content: flex-end; }
.btn-translate { background: #e0e0e0; color: #fff; border-radius: 40rpx; font-size: 28rpx; margin: 0; width: 200rpx;}